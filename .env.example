# Copy to `.env` and fill in. Only the provider selected in skb/config.json needs a key.
# The .env file is git-ignored; this .example is the tracked template.

# OpenRouter (default provider)
OPENROUTER_API_KEY=sk-or-...

# Google Gemini (direct, OpenAI-compatible endpoint)
GEMINI_API_KEY=

# Ollama (local) — any non-empty value works; no real key needed
OLLAMA_API_KEY=ollama
